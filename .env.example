# AccessSphere AI - Configuration Environment Variables

# 1. Google Gemini AI credentials
# Get a free key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override default model (gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# 2. Redis Rate Limiter Configuration (Optional)
# If left blank, the server will default to safe in-memory rate limiting.
# REDIS_URL=redis://localhost:6379

# 3. Server Configuration (Optional)
# PORT=8000
